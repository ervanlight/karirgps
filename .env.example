# ============================================================
# KARIRGPS — ENVIRONMENT VARIABLES
# Copy file ini ke .env.local dan isi nilainya
# JANGAN commit .env.local ke Git!
# ============================================================

# Supabase — ambil dari: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # hanya di server

# Anthropic — ambil dari: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Midtrans — ambil dari: https://dashboard.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=SB-Mid-server-...    # sandbox key untuk development
MIDTRANS_CLIENT_KEY=SB-Mid-client-...   # dipakai di frontend untuk Snap popup
# Ganti ke production key saat launch:
# MIDTRANS_SERVER_KEY=Mid-server-...
# MIDTRANS_CLIENT_KEY=Mid-client-...

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000   # ganti ke https://karirgps.id di production

# Resend (email) — ambil dari: https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=laporan@karirgps.id
